# ─── MongoDB Atlas ───
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/real-time-chat?retryWrites=true&w=majority

# ─── Upstash Redis (free: 256 MB) ───
# Get URL: console.upstash.com → Create Database → Copy REDIS_URL
REDIS_URL=redis://default:<password>@your-db.upstash.io:6379

# ─── JWT ───
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=7d

# ─── Server ───
PORT=5000
NODE_ENV=development

# ─── Client (for CORS) ───
CLIENT_URL=http://localhost:5173
